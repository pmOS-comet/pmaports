# Reference: <https://postmarketos.org/vendorkernel>
# Kernel config based on: arch/arm64/configs/vendor/lineage-a52sxq_defconfig

pkgname=linux-samsung-a52sxq
pkgver=5.4.254
pkgrel=0
pkgdesc="Samsung Galaxy A52s 5G kernel fork"
arch="aarch64"
_carch="arm64"
_flavor="samsung-a52sxq"
url="https://kernel.org"
license="GPL-2.0-only"
options="!strip !check !tracedeps pmb:cross-native"
makedepends="
	bash
	bc
	bison
	cpio
	devicepkg-dev
	findutils
	flex
	openssl-dev
	perl
	tar
	xz
"

# Source
_repository="android_kernel_samsung_sm7325"
_commit="12334aaea98147c1739de857b4f36f8949a3f095"
_config="config-$_flavor.$arch"
source="
	$pkgname-$_commit.tar.gz::https://github.com/LineageOS/$_repository/archive/$_commit.tar.gz
	$_config
	fix-camera-include-paths.patch
"
builddir="$srcdir/$_repository-$_commit"
_outdir="out"

prepare() {
	default_prepare
	REPLACE_GCCH=0 . downstreamkernel_prepare
}

build() {
	unset LDFLAGS
	make O="$_outdir" ARCH="$_carch" CC="${CC:-gcc}" \
		KBUILD_BUILD_VERSION="$((pkgrel + 1 ))-postmarketOS"
}

package() {
	downstreamkernel_package "$builddir" "$pkgdir" "$_carch" \
		"$_flavor" "$_outdir"

	mkdir -p  "$pkgdir"/usr/share/dtb
	cp "$_outdir"/arch/arm64/boot/dts/vendor/qcom/yupik.dtb "$pkgdir"/usr/share/dtb/a52sxq.dtb
}

