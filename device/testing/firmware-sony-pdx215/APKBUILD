maintainer="Jan Paszkowski <janmpaszkowski@proton.me>"
pkgname=firmware-sony-pdx215
pkgver=1
pkgrel=0
pkgdesc="Firmware for Sony Xperia 1 III"
url="https://gitlab.com/janmpaszkowski/sony-pdx215-firmware"
_repository="sony-pdx215-firmware"
_commit="2a9eabd337b60ef1209cbb238f20784f676a4c7f"
arch="aarch64"
license="proprietary"
options="!check !strip !archcheck !spdx !tracedeps pmb:cross-native"

source="$pkgname-$_commit.tar.gz::https://gitlab.com/janmpaszkowski/$_repository/-/archive/$_commit/$_repository-$_commit.tar.gz
firmware.files"

package() {
	cd "$srcdir/$_repository-$_commit"
	while IFS="" read -r _i || [ -n "$_i" ]; do
		[ ! -d $(dirname $_i) ] && mkdir -p $(dirname $_i)
		echo $_i
		install -Dm644 $_i "$pkgdir/$_i"
	done < "$srcdir/firmware.files"
}

