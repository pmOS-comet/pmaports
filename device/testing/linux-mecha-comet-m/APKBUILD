014372afb67c418410e16c35e90c6f980c92fdedb70b9f2ac97ae6660c2d1a3a1b459b8a1dcacfba9741ba10fb1753f94dde4c4fc8208813180d800f2bfe735c  config-mecha-comet-m.aarch64
"
