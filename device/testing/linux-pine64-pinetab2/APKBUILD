79c703b30bff1f386d7edb4417160d9d8ea0c6bb0fee9710f79e6dee65f09815254249c738564085ce3a07d21a8d6ba22bcfd931e94b4311dde779ad93f2f76a  config-pine64-pinetab2.aarch64
"
