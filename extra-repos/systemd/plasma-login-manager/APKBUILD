# The group tag is just to easily find this APKBUILD by some scripts for automation
# group=kde-plasma
maintainer="team/kde <bribbers@disroot.org>"
pkgname=plasma-login-manager
pkgver=6.6.1
pkgrel=0
pkgdesc="A display manager for KDE Plasma"
# armhf blocked by qt6-qtdeclarative
arch="all !armhf"
url="https://kde.org/plasma-desktop"
license="GPL-2.0-or-later"
makedepends="
	doxygen
	extra-cmake-modules
	graphviz
	kauth-dev
	kcmutils-dev
	kconfig-dev
	kdbusaddons-dev
	kde-qdoc-common
	ki18n-dev
	kio-dev
	kpackage-dev
	kwindowsystem-dev
	layer-shell-qt-dev
	linux-pam-dev
	libxau-dev
	plasma-workspace-dev
	qt6-qtbase-dev
	qt6-qtdeclarative-dev
	qt6-qttools-dev
	samurai
	systemd-dev
	"
subpackages="
	$pkgname-lang
	$pkgname-systemd
	"

case "$pkgver" in
	*.*.9*) _rel=unstable;;
	*) _rel=stable;;
esac

# strip fourth version component for source URL
case "$pkgver" in
	*.*.*.*) _pkgver="${pkgver%.*}" ;;
	*) _pkgver="$pkgver" ;;
esac

_repo_url="https://invent.kde.org/plasma/plasma-login-manager.git"
source="https://download.kde.org/$_rel/plasma/$_pkgver/plasma-login-manager-$pkgver.tar.xz
	plasmalogin.pam
	plasmalogin-autologin.pam
	plasmalogin-greeter.pam
	"

build() {
	cmake -B build -G Ninja \
		-DCMAKE_BUILD_TYPE=RelWithDebInfo \
		-DCMAKE_INSTALL_PREFIX=/usr \
		-DCMAKE_INSTALL_LIBDIR=lib \
		-DINSTALL_PAM_CONFIGURATION=OFF
	cmake --build build
}

check() {
	ctest --test-dir build
}

package() {
	DESTDIR="$pkgdir" cmake --install build

	install -Dm644 "$srcdir"/plasmalogin.pam "$pkgdir"/usr/lib/pam.d/plasmalogin
	install -Dm644 "$srcdir"/plasmalogin-autologin.pam "$pkgdir"/usr/lib/pam.d/plasmalogin-autologin
	install -Dm644 "$srcdir"/plasmalogin-greeter.pam "$pkgdir"/usr/lib/pam.d/plasmalogin-greeter
}


